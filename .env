# =====================================================================
# 🏛️ CONFIGURACIÓN DE TU APP FINFLOW (NEGOCIO)
# =====================================================================
# Ruta local del archivo SQLite para desarrollo. 
# Docker Compose usa la misma variable DB_PATH y la sustituye con /app/data/finflow.db.
DB_PATH=./data/finflow.db

# =====================================================================
# ⚙️ CONFIGURACIÓN DE LA INFRAESTRUCTURA DE FEATURE FLAGS (UNLEASH)
# =====================================================================
# Datos para la base de datos Postgres interna de Unleash
UNLEASH_DB_NAME=unleash_system
UNLEASH_DB_USER=admin_devops
UNLEASH_DB_PASSWORD=password_super_seguro_123

# Token secreto para que tu app de Go autentique contra la API de Unleash
# (Mantenemos el formato estándar que acepta la imagen por defecto)
UNLEASH_SECRET_TOKEN=*:*.unleash-insecure-api-token
UNLEASH_APP_NAME=finflow-backend
UNLEASH_URL=http://localhost:4242/api/
UNLEASH_TOKEN=default:development.unleash-insecure-api-token
